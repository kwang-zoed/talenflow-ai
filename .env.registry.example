# 镜像仓库发布配置
# 复制为 .env.registry 后修改：Copy-Item .env.registry.example .env.registry

# Docker Hub 示例：DOCKER_REGISTRY=docker.io  DOCKER_NAMESPACE=你的用户名
# 阿里云示例：DOCKER_REGISTRY=registry.cn-hangzhou.aliyuncs.com  DOCKER_NAMESPACE=你的命名空间
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=your-dockerhub-username
IMAGE_TAG=latest

# 构建完成后生成的镜像名（一般无需改）
#   ${DOCKER_REGISTRY}/${DOCKER_NAMESPACE}/talentflow-backend:${IMAGE_TAG}
#   ${DOCKER_REGISTRY}/${DOCKER_NAMESPACE}/talentflow-frontend:${IMAGE_TAG}

# 说明：mysql、redis 使用官方镜像，无需推送；只推送 backend（含 MCP/Celery 同镜像）和 frontend
