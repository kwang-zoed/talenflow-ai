# 远程服务器生产环境 .env 模板
# 在服务器上：cp .env.production.example .env && nano .env

# ========== 必改项 ==========
MYSQL_ROOT_PASSWORD=请改成强密码
MYSQL_PASSWORD=请改成强密码
REDIS_PASSWORD=请改成强密码
SECRET_KEY=请改成随机长字符串至少32位
OPENAI_API_KEY=sk-你的密钥

# ========== 数据库 ==========
MYSQL_DATABASE=dandelion_tribe
MYSQL_USER=talentflow
MYSQL_SERVER=mysql
MYSQL_PORT=3306

# ========== Redis / Celery ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:请改成与REDIS_PASSWORD相同@redis:6379/0
CELERY_BROKER_URL=redis://:请改成与REDIS_PASSWORD相同@redis:6379/0
CELERY_RESULT_BACKEND=redis://:请改成与REDIS_PASSWORD相同@redis:6379/1

# ========== AI ==========
OPENAI_API_BASE=https://api.deepseek.com/v1

# ========== Docker 内服务通信（不要改） ==========
MCP_SERVER_URL=http://mcp-server:8002/mcp
MCP_HOST=0.0.0.0
MCP_PORT=8002
CHECKPOINTER_BACKEND=sqlite
SQLITE_CHECKPOINT_PATH=/app/data/langgraph_checkpoints.sqlite

# ========== 运行策略 ==========
PRELOAD_MODELS_ON_STARTUP=false
SMART_APPLY_HUMAN_REVIEW=true

# ========== 对外端口（生产只暴露前端 80） ==========
FRONTEND_PUBLISH_PORT=80

# 以下留空或不设置 = 不对外暴露（prod compose 已关闭）
# MYSQL_PUBLISH_PORT=
# REDIS_PUBLISH_PORT=
# API_PUBLISH_PORT=
# MCP_PUBLISH_PORT=
