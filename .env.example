# ========== 复制为 .env 后修改 ==========
#
# Windows PowerShell（在项目根目录 talentflow-ai/ 执行）：
#   Copy-Item .env.example .env
#
# macOS / Linux：
#   cp .env.example .env
#
# 注意：
# 1. Docker Compose 只读【项目根目录】的 .env，不是 talentflow-ai-backend-bak/.env
# 2. 复制后必须把 change_me_* 改成真实密码，并填入 OPENAI_API_KEY
# 3. 若根目录已有 .env，Copy-Item 不会覆盖，需手动编辑或加 -Force

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=dandelion_tribe
MYSQL_USER=talentflow
MYSQL_PASSWORD=change_me_db
MYSQL_SERVER=mysql
MYSQL_PORT=3306
# 本机 3306 被占用时改为 3307（仅影响宿主机端口映射）
# MYSQL_PUBLISH_PORT=3307

# Redis（Celery broker / result backend）
REDIS_PASSWORD=change_me_redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:change_me_redis@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_redis@redis:6379/1
# Celery 任务结果在 Redis 中的保留时间（秒），默认 86400（24h）
CELERY_RESULT_EXPIRES=86400

# FastAPI / Agent
SECRET_KEY=change_me_jwt_secret
# 双令牌：短时令牌（滑动续期）+ 长时刷新令牌
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OPENAI_API_KEY=your_deepseek_or_openai_key
OPENAI_API_BASE=https://api.deepseek.com/v1

# 服务间通信（Docker 网络内服务名）
MCP_SERVER_URL=http://mcp-server:8002/mcp
MCP_HOST=0.0.0.0
MCP_PORT=8002

# LangGraph Checkpointer（普通 Redis 无 RediSearch，建议 sqlite）
CHECKPOINTER_BACKEND=sqlite
SQLITE_CHECKPOINT_PATH=/app/data/langgraph_checkpoints.sqlite

# 向量库目录（挂载 volume，容器内固定路径）
# FAISS 索引实际目录为 app/rag/../../vector_store

# 启动行为
PRELOAD_MODELS_ON_STARTUP=false
SMART_APPLY_HUMAN_REVIEW=true

# 高德地图 Web 服务 Key（地理编码，用于距离计算）
AMAP_WEB_KEY=your_amap_web_service_key
AMAP_GEOCODE_ENABLED=true

# Docker 基础镜像（国内网络勿直连 docker.io；海外可改回 python:3.11-slim-bookworm 等）
DOCKER_PYTHON_BASE=docker.m.daocloud.io/library/python:3.11-slim-bookworm
DOCKER_NODE_BASE=docker.m.daocloud.io/library/node:18-alpine
DOCKER_NGINX_BASE=docker.m.daocloud.io/library/nginx:stable-alpine
DOCKER_MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
DOCKER_REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
